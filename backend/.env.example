# ============================================================
# VOXAR Backend — Environment Variables Reference
# ============================================================
# For Railway: set these in the Railway dashboard under Variables.
# For local dev: copy this file to .env and fill in values.
# ============================================================

# ---------- Server ----------
PORT=3001
NODE_ENV=development

# ---------- MongoDB ----------
MONGODB_URI=mongodb://localhost:27017/voxar

# ---------- JWT ----------
# CRITICAL: Generate a strong secret for production!
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ---------- Engine Mode ----------
# 'local' = direct FastAPI engine (dev mode)
# 'runpod' = serverless GPU via Redis queue (production)
VOXAR_ENGINE_MODE=local

# ---------- Python Engine (local mode only) ----------
PYTHON_ENGINE_URL=http://localhost:8000
ENGINE_API_KEY=voxar-dev-key-001

# ---------- Redis (runpod mode only) ----------
# For Upstash: use native Redis URL (NOT the REST URL)
# Format: rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ---------- RunPod (runpod mode only) ----------
RUNPOD_API_KEY=YOUR_RUNPOD_API_KEY_HERE
RUNPOD_ENDPOINT_ID=YOUR_RUNPOD_ENDPOINT_ID_HERE

# ---------- Cloudflare R2 Storage ----------
# Map from Cloudflare dashboard:
#   Cloudflare Account ID → R2_ACCOUNT_ID
#   R2 API Token Access Key → R2_ACCESS_KEY_ID
#   R2 API Token Secret Key → R2_SECRET_ACCESS_KEY
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_KEY
R2_BUCKET_NAME=voxar
R2_PUBLIC_URL_PREFIX=https://audio.voxar.in

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:3000

# ---------- Razorpay ----------
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ---------- Uploads ----------
UPLOAD_DIR=./uploads
